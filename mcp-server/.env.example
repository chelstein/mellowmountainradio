# AzuraCast instance (no trailing slash)
AZ_HOST=https://streaming.mellowmountainradio.com

# AzuraCast station short name or numeric ID
STATION_ID=kazm

# AzuraCast API key (needed for song history; now-playing is public)
AZ_KEY=

# GitHub raw base URL for KAZM JSON data files
GH_RAW=https://raw.githubusercontent.com/chelstein/mellowmountainradio/main

# HTTP port (default: 3000)
PORT=3000
